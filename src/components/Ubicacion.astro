---
import { invitacion } from "../config/invitacion";
const { recepcion } = invitacion;
const q = encodeURIComponent(recepcion.mapsQuery);
const mapEmbed = `https://maps.google.com/maps?q=${q}&z=15&output=embed`;
---

<section id="ubicacion" class="ubicacion py-20 sm:py-28 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <div class="reveal" data-stagger>
      <p class="kicker">Cómo llegar</p>
      <h2 class="font-display text-tinta text-4xl sm:text-5xl font-medium mt-3">
        {recepcion.lugar}
      </h2>
      <p class="dir mt-2">{recepcion.direccion}</p>
      <div class="filete my-6"><span>✦</span></div>
    </div>

    <div class="reveal mapa-caja" data-mapa data-src={mapEmbed}>
      <div class="mapa-placeholder">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>Cargando mapa…</span>
      </div>
    </div>

    <div class="reveal mt-7 flex flex-wrap gap-3 justify-center">
      <a
        class="btn btn-primario"
        href={recepcion.mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <span>Abrir en Google Maps</span>
      </a>
    </div>
  </div>
</section>

<script>
  // Carga perezosa del iframe del mapa: solo cuando se acerca al viewport
  const caja = document.querySelector<HTMLElement>("[data-mapa]");
  if (caja) {
    const src = caja.dataset.src!;
    const cargar = () => {
      const iframe = document.createElement("iframe");
      iframe.src = src;
      iframe.loading = "lazy";
      iframe.title = "Mapa de la recepción";
      iframe.setAttribute("referrerpolicy", "no-referrer-when-downgrade");
      iframe.style.width = "100%";
      iframe.style.height = "100%";
      iframe.style.border = "0";
      iframe.addEventListener("load", () => caja.classList.add("cargado"));
      caja.appendChild(iframe);
    };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              cargar();
              obs.disconnect();
            }
          });
        },
        { rootMargin: "300px" }
      );
      io.observe(caja);
    } else {
      cargar();
    }
  }
</script>

<style>
  .ubicacion { background: var(--marfil-hondo); }
  .dir {
    font-family: "Jost", sans-serif;
    color: var(--tinta);
    opacity: 0.75;
    letter-spacing: 0.03em;
  }
  .mapa-caja {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--sombra-carta);
    border: 4px solid #fff;
    aspect-ratio: 16 / 11;
    background: var(--marfil);
  }
  .mapa-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    color: var(--polvo);
    font-family: "Jost", sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    transition: opacity 0.5s ease;
  }
  .mapa-caja.cargado .mapa-placeholder {
    opacity: 0;
    pointer-events: none;
  }
  @media (min-width: 640px) {
    .mapa-caja { aspect-ratio: 16 / 9; }
  }
</style>
