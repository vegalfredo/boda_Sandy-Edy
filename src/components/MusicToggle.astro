---
import { invitacion } from "../config/invitacion";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const asset = (p: string) => `${base}/${p.replace(/^\//, "")}`;
const { musica } = invitacion;
---

<div class="musica-wrap">
  <div id="tooltip-musica" class="tooltip">Toca para escuchar nuestra canción</div>
  <button
    id="btn-musica"
    class="btn-musica"
    aria-label="Reproducir música"
    aria-pressed="false"
  >
    <!-- Icono nota (pausado) -->
    <svg class="ic-nota" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18V5l12-2v13"/>
      <circle cx="6" cy="18" r="3"/>
      <circle cx="18" cy="16" r="3"/>
    </svg>
    <!-- Ecualizador (reproduciendo) -->
    <span class="ecualizador" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </span>
  </button>
  <audio id="audio-boda" src={asset(musica.archivo)} preload="none" loop></audio>
</div>

<script>
  const btn = document.getElementById("btn-musica") as HTMLButtonElement;
  const audio = document.getElementById("audio-boda") as HTMLAudioElement;
  const tooltip = document.getElementById("tooltip-musica")!;
  const VOL_MAX = 0.55;
  let fadeTimer: number | undefined;

  // Mostrar el tooltip una vez, luego ocultarlo
  let tooltipVisto = false;
  try {
    tooltipVisto = localStorage.getItem("musica-tooltip") === "1";
  } catch {}
  if (!tooltipVisto) {
    setTimeout(() => tooltip.classList.add("visible"), 1600);
    setTimeout(() => ocultarTooltip(), 7000);
  }
  function ocultarTooltip() {
    tooltip.classList.remove("visible");
    try {
      localStorage.setItem("musica-tooltip", "1");
    } catch {}
  }

  function fade(desde: number, hasta: number, cb?: () => void) {
    clearInterval(fadeTimer);
    audio.volume = desde;
    const paso = (hasta - desde) / 20;
    fadeTimer = window.setInterval(() => {
      let v = audio.volume + paso;
      if ((paso > 0 && v >= hasta) || (paso < 0 && v <= hasta)) {
        v = hasta;
        clearInterval(fadeTimer);
        cb?.();
      }
      audio.volume = Math.max(0, Math.min(1, v));
    }, 40);
  }

  async function reproducir() {
    try {
      audio.volume = 0;
      await audio.play();
      fade(0, VOL_MAX);
      btn.classList.add("sonando");
      btn.setAttribute("aria-pressed", "true");
      btn.setAttribute("aria-label", "Pausar música");
    } catch {
      /* el navegador bloqueó la reproducción; no pasa nada */
    }
  }
  function pausar() {
    fade(audio.volume, 0, () => audio.pause());
    btn.classList.remove("sonando");
    btn.setAttribute("aria-pressed", "false");
    btn.setAttribute("aria-label", "Reproducir música");
  }

  btn.addEventListener("click", () => {
    ocultarTooltip();
    if (audio.paused) reproducir();
    else pausar();
  });
</script>

<style>
  .musica-wrap {
    position: fixed;
    top: max(0.9rem, env(safe-area-inset-top));
    right: max(0.9rem, env(safe-area-inset-right));
    z-index: 60;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .btn-musica {
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: rgba(42, 36, 56, 0.72);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(201, 169, 106, 0.6);
    color: var(--marfil);
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow: var(--sombra-suave);
    transition: transform 0.2s ease, background 0.3s ease;
  }
  .btn-musica:hover { transform: scale(1.06); }
  .btn-musica:active { transform: scale(0.94); }
  .btn-musica.sonando { background: var(--vino); border-color: var(--champagne); }

  .btn-musica .ecualizador { display: none; gap: 2px; align-items: flex-end; height: 18px; }
  .btn-musica.sonando .ic-nota { display: none; }
  .btn-musica.sonando .ecualizador { display: flex; }
  .ecualizador span {
    width: 3px;
    background: var(--champagne);
    border-radius: 2px;
    animation: eq 0.9s ease-in-out infinite;
  }
  .ecualizador span:nth-child(1) { height: 8px; animation-delay: 0s; }
  .ecualizador span:nth-child(2) { height: 16px; animation-delay: 0.2s; }
  .ecualizador span:nth-child(3) { height: 11px; animation-delay: 0.4s; }
  .ecualizador span:nth-child(4) { height: 15px; animation-delay: 0.15s; }
  @keyframes eq {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }

  .tooltip {
    background: var(--marfil);
    color: var(--tinta);
    font-family: "Jost", sans-serif;
    font-size: 0.78rem;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    box-shadow: var(--sombra-suave);
    white-space: nowrap;
    opacity: 0;
    transform: translateX(10px);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
    border: var(--borde-fino);
  }
  .tooltip.visible { opacity: 1; transform: translateX(0); }

  @media (prefers-reduced-motion: reduce) {
    .ecualizador span { animation: none; }
  }
  @media (max-width: 420px) {
    .tooltip { font-size: 0.72rem; max-width: 44vw; white-space: normal; }
  }
</style>
