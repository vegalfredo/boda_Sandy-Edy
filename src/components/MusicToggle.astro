---
import { invitacion } from "../config/invitacion";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const asset = (p: string) => `${base}/${p.replace(/^\//, "")}`;
const { musica } = invitacion;
---

<div class="musica-wrap">
  <div id="tooltip-musica" class="tooltip">Toca aquí para silenciar la música 🔇</div>
  <button
    id="btn-musica"
    class="btn-musica sonando"
    aria-label="Silenciar música"
    aria-pressed="true"
  >
    <!-- Icono nota (pausado) -->
    <svg class="ic-nota" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18V5l12-2v13"/>
      <circle cx="6" cy="18" r="3"/>
      <circle cx="18" cy="16" r="3"/>
    </svg>
    <!-- Ecualizador (reproduciendo) -->
    <span class="ecualizador" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </span>
  </button>
  <audio id="audio-boda" src={asset(musica.archivo)} preload="auto" loop></audio>
</div>

<script>
  const btn = document.getElementById("btn-musica") as HTMLButtonElement;
  const audio = document.getElementById("audio-boda") as HTMLAudioElement;
  const tooltip = document.getElementById("tooltip-musica")!;
  const VOL_MAX = 0.55;
  let fadeTimer: number | undefined;

  // El usuario silenció manualmente: no volver a arrancar por gesto.
  let silenciadoPorUsuario = false;

  function ocultarTooltip() {
    tooltip.classList.remove("visible");
  }

  function fade(desde: number, hasta: number, cb?: () => void) {
    clearInterval(fadeTimer);
    audio.volume = desde;
    const paso = (hasta - desde) / 20;
    fadeTimer = window.setInterval(() => {
      let v = audio.volume + paso;
      if ((paso > 0 && v >= hasta) || (paso < 0 && v <= hasta)) {
        v = hasta;
        clearInterval(fadeTimer);
        cb?.();
      }
      audio.volume = Math.max(0, Math.min(1, v));
    }, 40);
  }

  function marcarSonando() {
    btn.classList.add("sonando");
    btn.setAttribute("aria-pressed", "true");
    btn.setAttribute("aria-label", "Silenciar música");
  }
  function marcarSilencio() {
    btn.classList.remove("sonando");
    btn.setAttribute("aria-pressed", "false");
    btn.setAttribute("aria-label", "Reproducir música");
  }

  async function reproducir() {
    try {
      audio.volume = 0;
      await audio.play();
      fade(0, VOL_MAX);
      marcarSonando();
      return true;
    } catch {
      // El navegador bloqueó la reproducción automática.
      return false;
    }
  }
  function pausar() {
    fade(audio.volume, 0, () => audio.pause());
    marcarSilencio();
  }

  // ── Arranque automático de la canción ──────────────────────────────
  // 1) Intentamos reproducir de inmediato al cargar.
  // 2) Si el navegador lo bloquea (celulares, WhatsApp), lo dejamos listo
  //    para que arranque solo en el PRIMER gesto del usuario (toque, scroll
  //    o tecla), lo cual ocurre en el primer segundo de la visita.
  // Eventos que SÍ cuentan como "gesto de activación" en todos los navegadores.
  // En iOS Safari solo valen los de soltar/clic (touchend/click/pointerup/keydown);
  // 'touchstart' y 'scroll' van como respaldo por si el navegador los acepta.
  const eventosGesto = [
    "click",
    "touchend",
    "pointerup",
    "keydown",
    "touchstart",
    "scroll",
  ] as const;

  function quitarEnganches() {
    eventosGesto.forEach((ev) =>
      window.removeEventListener(ev, alPrimerGesto, true)
    );
  }
  async function alPrimerGesto(e: Event) {
    // Si el gesto es sobre el propio botón, que lo maneje su onclick.
    if (e.target instanceof Node && btn.contains(e.target)) {
      quitarEnganches();
      return;
    }
    if (silenciadoPorUsuario || !audio.paused) {
      quitarEnganches();
      return;
    }
    const ok = await reproducir();
    if (ok) quitarEnganches();
  }

  function engancharGestos() {
    eventosGesto.forEach((ev) =>
      // capture:true para atraparlo antes que nada; sin passive para que
      // audio.play() cuente como iniciado por el usuario.
      window.addEventListener(ev, alPrimerGesto, { capture: true })
    );
  }

  (async () => {
    const ok = await reproducir();
    // Aunque el autoplay funcione, dejamos los gestos enganchados: si el
    // navegador lo bloqueó silenciosamente, el primer toque lo arrancará.
    if (!ok) engancharGestos();
    setTimeout(() => tooltip.classList.add("visible"), 1800);
    setTimeout(ocultarTooltip, 8000);
  })();

  // ── Botón: alterna entre sonar y silenciar ─────────────────────────
  btn.addEventListener("click", () => {
    ocultarTooltip();
    if (audio.paused) {
      silenciadoPorUsuario = false;
      reproducir();
    } else {
      silenciadoPorUsuario = true;
      pausar();
    }
  });
</script>

<style>
  .musica-wrap {
    position: fixed;
    top: max(0.9rem, env(safe-area-inset-top));
    right: max(0.9rem, env(safe-area-inset-right));
    z-index: 60;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .btn-musica {
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: rgba(42, 36, 56, 0.72);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(201, 169, 106, 0.6);
    color: var(--marfil);
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow: var(--sombra-suave);
    transition: transform 0.2s ease, background 0.3s ease;
  }
  .btn-musica:hover { transform: scale(1.06); }
  .btn-musica:active { transform: scale(0.94); }
  .btn-musica.sonando { background: var(--vino); border-color: var(--champagne); }

  .btn-musica .ecualizador { display: none; gap: 2px; align-items: flex-end; height: 18px; }
  .btn-musica.sonando .ic-nota { display: none; }
  .btn-musica.sonando .ecualizador { display: flex; }
  .ecualizador span {
    width: 3px;
    background: var(--champagne);
    border-radius: 2px;
    animation: eq 0.9s ease-in-out infinite;
  }
  .ecualizador span:nth-child(1) { height: 8px; animation-delay: 0s; }
  .ecualizador span:nth-child(2) { height: 16px; animation-delay: 0.2s; }
  .ecualizador span:nth-child(3) { height: 11px; animation-delay: 0.4s; }
  .ecualizador span:nth-child(4) { height: 15px; animation-delay: 0.15s; }
  @keyframes eq {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }

  .tooltip {
    background: var(--marfil);
    color: var(--tinta);
    font-family: "Jost", sans-serif;
    font-size: 0.78rem;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    box-shadow: var(--sombra-suave);
    white-space: nowrap;
    opacity: 0;
    transform: translateX(10px);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
    border: var(--borde-fino);
  }
  .tooltip.visible { opacity: 1; transform: translateX(0); }

  @media (prefers-reduced-motion: reduce) {
    .ecualizador span { animation: none; }
  }
  @media (max-width: 420px) {
    .tooltip { font-size: 0.72rem; max-width: 44vw; white-space: normal; }
  }
</style>
