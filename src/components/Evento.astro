---
import { invitacion } from "../config/invitacion";
const { padres, recepcion, fechaTexto, horaTexto, novios } = invitacion;
---

<section id="evento" class="evento py-20 sm:py-28 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <!-- Bendición / padres -->
    <div class="reveal" data-stagger>
      <p class="kicker">Con la bendición de nuestros padres</p>
      <div class="padres mt-8">
        <div class="padres-col">
          {padres.novia.map((p) => <p class="padre">{p}</p>)}
        </div>
        <span class="padres-amp font-script">&amp;</span>
        <div class="padres-col">
          {padres.novio.map((p) => <p class="padre">{p}</p>)}
        </div>
      </div>
      <p class="invitan mt-8">
        Tenemos el honor de invitarte a celebrar la unión de
      </p>
      <p class="font-script novios-nombre">{novios.ella} <span class="amp-chico">&amp;</span> {novios.el}</p>
    </div>

    <div class="filete my-10"><span>✦</span></div>

    <!-- Tarjeta de recepción -->
    <div class="reveal tarjeta" data-stagger>
      <span class="tarjeta-icono" aria-hidden="true">
        <!-- Brindis: dos copas -->
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3l2.2 6.2a3 3 0 0 1-2.1 3.9M8 3H3.5l2.4 6.2a3 3 0 0 0 2.1 3.9M6 21h5M8.1 13.1V21"/>
          <path d="M16 3l-2.2 6.2a3 3 0 0 0 2.1 3.9M16 3h4.5l-2.4 6.2a3 3 0 0 1-2.1 3.9M18 21h-5M15.9 13.1V21"/>
          <path d="M9.6 6.5l4.8-1.4"/>
        </svg>
      </span>
      <p class="kicker">Recepción</p>
      <h3 class="font-display tarjeta-lugar">{recepcion.lugar}</h3>
      <p class="tarjeta-dir">{recepcion.direccion}</p>
      <div class="tarjeta-datos">
        <div>
          <span class="dato-num font-display">{fechaTexto.split(" ")[1]}</span>
          <span class="dato-etq">Sábado · Agosto 2026</span>
        </div>
        <span class="divisor" aria-hidden="true"></span>
        <div>
          <span class="dato-num font-display">{horaTexto}</span>
          <span class="dato-etq">Nos vemos a esta hora</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .evento {
    background: var(--marfil-hondo);
  }
  .padres {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.8rem, 4vw, 2.5rem);
    flex-wrap: wrap;
  }
  .padres-col { display: flex; flex-direction: column; gap: 0.15rem; }
  .padre {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.05rem, 4.4vw, 1.35rem);
    color: var(--tinta);
    line-height: 1.35;
  }
  .padres-amp {
    font-size: clamp(2rem, 9vw, 3rem);
    color: var(--champagne);
    line-height: 1;
  }
  .invitan {
    font-family: "Jost", sans-serif;
    font-weight: 300;
    color: var(--vino);
    letter-spacing: 0.04em;
    font-size: 0.95rem;
  }
  .novios-nombre {
    font-size: clamp(3rem, 15vw, 5rem);
    color: var(--tinta);
    line-height: 1.1;
    margin-top: 0.2rem;
  }
  .amp-chico { color: var(--champagne); }

  .tarjeta {
    background: var(--marfil);
    border: var(--borde-fino);
    border-radius: 22px;
    padding: 2.6rem 1.6rem 2.2rem;
    box-shadow: var(--sombra-suave);
    position: relative;
    max-width: 30rem;
    margin: 0 auto;
  }
  .tarjeta-icono {
    display: inline-grid;
    place-items: center;
    width: 62px;
    height: 62px;
    border-radius: 999px;
    background: var(--marfil-hondo);
    color: var(--vino);
    margin-bottom: 0.8rem;
  }
  .tarjeta-lugar {
    font-size: clamp(1.9rem, 8vw, 2.6rem);
    font-weight: 500;
    color: var(--tinta);
    margin-top: 0.3rem;
  }
  .tarjeta-dir {
    font-family: "Jost", sans-serif;
    color: var(--tinta);
    opacity: 0.75;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
  }
  .tarjeta-datos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    margin-top: 1.6rem;
  }
  .tarjeta-datos > div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .dato-num {
    font-size: clamp(1.8rem, 8vw, 2.4rem);
    font-weight: 500;
    color: var(--vino);
    line-height: 1;
  }
  .dato-etq {
    font-family: "Jost", sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tinta);
    opacity: 0.65;
  }
  .divisor {
    width: 1px;
    align-self: stretch;
    background: rgba(201, 169, 106, 0.5);
  }
</style>
