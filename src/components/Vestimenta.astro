---
import { invitacion } from "../config/invitacion";
const { vestimenta } = invitacion;
---

<section id="vestimenta" class="vestimenta py-20 sm:py-28 px-6">
  <div class="max-w-2xl mx-auto text-center reveal" data-stagger>
    <p class="kicker">Código de vestimenta</p>

    <div class="iconos mt-6" aria-hidden="true">
      <!-- vestido -->
      <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 3h6l-1 3 3 4-2 2 3 9H6l3-9-2-2 3-4-1-3Z"/>
      </svg>
      <span class="sep">✦</span>
      <!-- traje / moño -->
      <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 3l6 4 6-4v3l-4 3 4 3v5H6v-5l4-3-4-3V3Z"/>
        <path d="M12 7v10"/>
      </svg>
    </div>

    <h2 class="font-display text-tinta text-4xl sm:text-5xl font-medium mt-4">
      {vestimenta.codigo}
    </h2>
    <p class="detalle mt-4">{vestimenta.detalle}</p>

    <div class="filete my-8"><span>✦</span></div>

    {vestimenta.paletaSugerida.length > 0 && (
      <>
        <p class="sub-etq">Paleta sugerida</p>
        <div class="paleta mt-4 mb-2">
          {vestimenta.paletaSugerida.map((c) => (
            <span class="circulo" style={`background:${c}`} title={c}></span>
          ))}
        </div>
      </>
    )}

    {vestimenta.coloresEvitar.length > 0 && (
      <div class="evitar mt-8">
        <span class="evitar-icono" aria-hidden="true">🤍</span>
        <p>
          Reservado para la novia, por favor evita el
          {" "}<strong>{vestimenta.coloresEvitar.join(" y ")}</strong>.
        </p>
      </div>
    )}
  </div>
</section>

<style>
  .vestimenta { background: var(--marfil); }
  .iconos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    color: var(--vino);
  }
  .sep { color: var(--champagne); font-size: 0.8rem; }
  .detalle {
    font-family: "Jost", sans-serif;
    font-weight: 300;
    color: var(--tinta);
    opacity: 0.82;
    max-width: 30rem;
    margin-inline: auto;
    line-height: 1.7;
  }
  .sub-etq {
    font-family: "Jost", sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--vino);
  }
  .paleta {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .circulo {
    width: 42px;
    height: 42px;
    border-radius: 999px;
    box-shadow: var(--sombra-suave);
    border: 2px solid #fff;
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .circulo:hover { transform: translateY(-3px) scale(1.06); }
  .evitar {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    justify-content: center;
    background: var(--marfil-hondo);
    border: var(--borde-fino);
    border-radius: 999px;
    padding: 0.8rem 1.4rem;
    max-width: 30rem;
    margin-inline: auto;
  }
  .evitar p {
    font-family: "Jost", sans-serif;
    font-size: 0.9rem;
    color: var(--tinta);
  }
  .evitar strong { color: var(--vino); font-weight: 500; }
  .evitar-icono { font-size: 1.1rem; }
</style>
