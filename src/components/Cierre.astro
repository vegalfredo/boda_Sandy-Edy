---
import { invitacion } from "../config/invitacion";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const asset = (p: string) => `${base}/${p.replace(/^\//, "")}`;
const { cierre, novios } = invitacion;
---

<section id="cierre" class="cierre relative py-28 sm:py-36 px-6 text-center overflow-hidden">
  <div class="cierre-fondo" aria-hidden="true">
    <img src={asset("fotos/2.webp")} alt="" class="h-full w-full object-cover" loading="lazy" decoding="async" />
  </div>
  <div class="cierre-velo" aria-hidden="true"></div>

  <div class="relative z-10 max-w-xl mx-auto reveal" data-stagger>
    <div class="monograma font-display">{novios.iniciales}</div>
    <p class="frase font-display">{cierre.frase}</p>
    <div class="filete filete-claro my-7"><span>✦</span></div>
    <p class="espera font-script">{cierre.despedida}</p>
    <a href="#confirmar" class="btn btn-contorno btn-claro mt-6">Confirmar mi asistencia</a>
  </div>
</section>

<footer class="footer">
  <p>Hecho con <span aria-hidden="true">🤍</span> para nuestra boda</p>
  <p class="footer-nombres font-script">{novios.ella} &amp; {novios.el} · 2026</p>
</footer>

<style>
  .cierre-fondo { position: absolute; inset: 0; z-index: 0; }
  .cierre-fondo img { filter: saturate(0.9); }
  .cierre-velo {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(42,36,56,.6), rgba(42,36,56,.72));
  }
  .monograma {
    font-style: italic;
    font-size: clamp(2.6rem, 12vw, 4rem);
    color: var(--champagne);
    line-height: 1;
    margin-bottom: 1.4rem;
  }
  .frase {
    font-size: clamp(1.8rem, 8vw, 3rem);
    font-style: italic;
    font-weight: 400;
    color: var(--marfil);
    line-height: 1.3;
  }
  .filete-claro { color: rgba(201,169,106,0.9); }
  .filete-claro::before, .filete-claro::after {
    background: linear-gradient(to var(--dir, right), transparent, rgba(201,169,106,0.9));
  }
  .espera {
    font-size: clamp(2.4rem, 11vw, 3.6rem);
    color: var(--marfil);
  }
  .btn-claro {
    color: var(--marfil);
    border-color: rgba(251,247,242,0.6);
  }
  .btn-claro:hover {
    background: var(--marfil);
    color: var(--tinta);
    border-color: var(--marfil);
  }

  .footer {
    background: var(--tinta);
    color: rgba(251,247,242,0.75);
    text-align: center;
    padding: 2.2rem 1rem;
    font-family: "Jost", sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }
  .footer-nombres {
    color: var(--champagne);
    font-size: 1.5rem;
    margin-top: 0.3rem;
    letter-spacing: 0;
  }
</style>
